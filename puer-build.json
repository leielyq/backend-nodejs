{
    "definition": ["WITH_NODEJS"],
    "include": [
        "/include",
        "/deps/v8/include",
        "/deps/uv/include"
    ],
    "skip": {
        "win": { "ia32": true }
    },
    "link-libraries": {
        "win": {
            "ia32": ["/Lib/Win32/libnode.lib"],
            "x64": ["/Lib/Win64/libnode.lib"]
        },
        "linux": {
            "x64": ["/lib/Linux/libnode.so.${NODE_MODULE_VERSION}"]
        }
    },
    "copy-libraries": {
        "win": {
            "ia32": ["/lib/Win32/libnode.dll", "/lib/Win32/node.exe"],
            "x64": ["/lib/Win64/libnode.dll", "/lib/Win64/node.exe"]
        },
        "linux": {
            "x64": ["/lib/Linux/libnode.so.${NODE_MODULE_VERSION}"]
        }
    }
}
