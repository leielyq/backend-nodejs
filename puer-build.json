{
    "definition": ["WITH_NODEJS"],
    "include": [
        "/include",
        "/deps/v8/include",
        "/deps/uv/include"
    ],
    "skip": {
        "win": { "ia32": true }
    },
    "link-libraries": {
        "win": {
            "ia32": ["/lib/Win32/libnode.lib"],
            "x64": ["/lib/Win64/libnode.lib"]
        },
        "linux": {
            "x64": ["/lib/Linux/libnode.so.${NODE_MODULE_VERSION}"]
        }
    },
    "copy-libraries": {
        "win": {
            "ia32": [
                "/lib/Win32/libnode.dll",
                "/lib/Win32/node.exe",
                "/lib/Win32/concrt140.dll",
                "/lib/Win32/msvcp140.dll",
                "/lib/Win32/msvcp140_1.dll",
                "/lib/Win32/msvcp140_2.dll",
                "/lib/Win32/msvcp140_atomic_wait.dll",
                "/lib/Win32/msvcp140_codecvt_ids.dll",
                "/lib/Win32/vccorlib140.dll",
                "/lib/Win32/vcruntime140.dll"
            ],
            "x64": [
                "/lib/Win64/libnode.dll",
                "/lib/Win64/node.exe",
                "/lib/Win64/concrt140.dll",
                "/lib/Win64/msvcp140.dll",
                "/lib/Win64/msvcp140_1.dll",
                "/lib/Win64/msvcp140_2.dll",
                "/lib/Win64/msvcp140_atomic_wait.dll",
                "/lib/Win64/msvcp140_codecvt_ids.dll",
                "/lib/Win64/vccorlib140.dll",
                "/lib/Win64/vcruntime140.dll",
                "/lib/Win64/vcruntime140_1.dll"
            ]
        },
        "linux": {
            "x64": ["/lib/Linux/libnode.so.${NODE_MODULE_VERSION}"]
        }
    }
}
